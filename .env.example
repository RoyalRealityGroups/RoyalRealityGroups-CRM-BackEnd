# ============================================
# Django Core Settings
# ============================================
DEBUG=False
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production-min-50-chars
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# URL Configuration
URL_SCHEMA=https
GLOBAL_API_URL=https://yourdomain.com

FRONTEND_URL==http://localhost:5000

# Safety Modes
SAFE_MODE=False
DYNAMICS_SAFE_MODE=False
FLOW_SAFE_MODE=False

# ============================================
# CORS Settings (REQUIRED in production!)
# ============================================
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# Database Configuration (REQUIRED)
# ============================================
DB_NAME=sales_db
DB_USER=postgres
DB_PASS=your-db-password
DB_HOST=localhost
DB_PORT=5432


# ============================================
# IO Server (Socket.IO) - REQUIRED
# ============================================
IO_SERVER_URL=http://localhost:5000
IO_SECRET=your-unique-io-secret-key-change-this

# ============================================
# Redis Cache (Optional)
# ============================================
USE_REDIS=False
REDIS_URL=redis://127.0.0.1:6379/1

# ============================================
# Focus ERP Integration (Optional)
# ============================================
FOCUS_SYNC_ON=False
FOCUS_BASEURL=
FOCUS_COMPANY_CODE=
FOCUS_USERNAME=
FOCUS_PASSWORD=
FOCUS_API2_BASEURL=
FOCUS_API2_TOKEN=

# ============================================
# AWS S3 Storage (Optional)
# ============================================
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-south-1

# ============================================
# Email Configuration (Optional)
# ============================================
# Configured via Django Dynamic Preferences in admin panel
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-email-password

# ============================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================
# Before going to production, verify:
# ✅ DEBUG=False
# ✅ DJANGO_SECRET_KEY is unique (50+ chars)
# ✅ IO_SECRET is unique
# ✅ DJANGO_ALLOWED_HOSTS set to actual domain
# ✅ CORS_ALLOWED_ORIGINS set to frontend domain
# ✅ URL_SCHEMA=https
# ✅ Strong database password
# ✅ AWS credentials if USE_S3=True
# ✅ .env is in .gitignore
# ✅ Run: python manage.py check --deploy
